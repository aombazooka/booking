# กันเข้าถึงไฟล์สลิปโดยตรง (ดูได้เฉพาะผ่าน api/slip.php ที่ต้อง login)
# Apache 2.4
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
# Apache 2.2
<IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
</IfModule>
# กันรันสคริปต์ในโฟลเดอร์อัปโหลด (เผื่อมีไฟล์อันตรายหลุดเข้ามา)
php_flag engine off
AddType text/plain .php .php3 .phtml .pl .py .cgi .asp .sh
